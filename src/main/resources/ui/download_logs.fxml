<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="550.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.stugger.logviewer.ui.DownloadLogsController">
   <children>
      <VBox prefHeight="200.0" prefWidth="100.0" AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="6.0" AnchorPane.rightAnchor="6.0" AnchorPane.topAnchor="6.0">
         <children>
            <HBox>
               <children>
                  <Label maxHeight="1.7976931348623157E308" text="Download Logs From:">
                     <HBox.margin>
                        <Insets right="4.0" />
                     </HBox.margin>
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Label>
                  <DatePicker fx:id="from_date" prefHeight="25.0" prefWidth="131.0" />
                  <Label maxHeight="1.7976931348623157E308" text="Include Previous:">
                     <HBox.margin>
                        <Insets left="6.0" right="4.0" />
                     </HBox.margin>
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Label>
                  <ComboBox fx:id="include_days" prefHeight="25.0" prefWidth="104.0" />
               </children>
            </HBox>
            <Separator prefWidth="200.0">
               <padding>
                  <Insets bottom="2.0" top="5.0" />
               </padding>
            </Separator>
            <TreeView fx:id="types_tree" prefHeight="392.0" prefWidth="488.0" VBox.vgrow="ALWAYS" />
            <ProgressBar fx:id="download_progress" prefHeight="0.0" prefWidth="500.0">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </ProgressBar>
            <HBox>
               <children>
                  <Button fx:id="download_button" defaultButton="true" mnemonicParsing="false" onAction="#on_click_download" prefHeight="34.0" prefWidth="241.0" text="Download">
                     <HBox.margin>
                        <Insets right="6.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="cancel_button" cancelButton="true" mnemonicParsing="false" onAction="#on_click_cancel" prefHeight="33.0" prefWidth="241.0" text="Cancel" />
               </children>
               <VBox.margin>
                  <Insets top="4.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
