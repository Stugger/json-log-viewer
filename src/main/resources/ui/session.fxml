<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.stugger.logviewer.ui.SessionController">
   <children>
        <ToolBar VBox.vgrow="NEVER">
            <Separator orientation="VERTICAL" />
         <Label text="Load Logs From:">
            <padding>
               <Insets left="-5.0" />
            </padding></Label>
         <DatePicker fx:id="audit_from" prefWidth="110.0" />
         <Label text="Include Previous:" />
         <ComboBox fx:id="audit_include_days" prefHeight="25.0" prefWidth="96.0" />
         <Separator />
         <Label text="Search:" />
         <TextField fx:id="search_field" maxWidth="1.7976931348623157E308" prefWidth="740.0" promptText="Search logs..." />
         <Separator orientation="VERTICAL" />
        </ToolBar>
      <SplitPane dividerPositions="0.13, 0.755" VBox.vgrow="ALWAYS">
        <items>
            <SplitPane dividerPositions="0.135" orientation="VERTICAL" prefHeight="200.0" prefWidth="160.0">
              <items>
                  <AnchorPane minHeight="116.0">
                     <children>
                        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                           <content>
                            <AnchorPane>
                                 <children>
                                    <VBox fx:id="player_selection_box" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                                 </children>
                              </AnchorPane>
                           </content>
                        </ScrollPane>
                        <Separator prefWidth="200.0" AnchorPane.bottomAnchor="18.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                        <Label styleClass="note" text="* Global logs filter to selected players." AnchorPane.bottomAnchor="1.0" AnchorPane.leftAnchor="4.0" AnchorPane.rightAnchor="2.0">
                           <font>
                              <Font size="10.0" />
                           </font></Label>
                     </children>
                  </AnchorPane>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="100.0" prefWidth="160.0">
                     <children>
                          <TreeView fx:id="toggle_tree" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                     </children>
                  </AnchorPane>
              </items>
            </SplitPane>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
               <children>
                    <TableView fx:id="logs_table" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                        <columns>
                            <TableColumn fx:id="time_column" text="Time" />
                        <TableColumn fx:id="scope_column" maxWidth="80.0" minWidth="40.0" prefWidth="40.0" text="Scope" />
                            <TableColumn fx:id="type_column" prefWidth="70.0" text="Type" />
                            <TableColumn fx:id="summary_column" maxWidth="1.7976931348623157E308" prefWidth="400.0" text="Summary" />
                        </columns>
                    </TableView>
               </children>
            </AnchorPane>
            <AnchorPane prefHeight="200.0" prefWidth="200.0">
               <children>
                    <TabPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                        <tabs>
                            <Tab closable="false" text="Details">
                                <ScrollPane fitToWidth="true">
                                    <VBox fx:id="details_box" spacing="8" styleClass="panel">
                                 <padding>
                                    <Insets top="8.0" />
                                 </padding></VBox>
                                </ScrollPane>
                            </Tab>
                            <Tab closable="false" text="Raw JSON">
                                <TextArea fx:id="raw_json" editable="false" wrapText="true" />
                            </Tab>
                         </tabs>
                    </TabPane>
               </children>
            </AnchorPane>
        </items>
      </SplitPane>
   </children>
</VBox>
